<section class="articles-preview" id="publications">
  <div class="section-head section-head--publications">
    <h2>Latest Publications</h2>
    <p class="section-subline">Insights, case studies, and technical publications.</p>
    <a href="/publications-projects/">View all publications →</a>
  </div>

  {% if collections.posts and collections.posts.length %}
    <div class="cards">
      {% for post in collections.posts | reverse %}
        {% if loop.index0 < 3 %}
          <article class="card">
            {% set publicationUrl = post.data.publication_link or post.url %}
            <h3><a href="{{ publicationUrl }}" {% if post.data.publication_link %}target="_blank" rel="noopener noreferrer"{% endif %}>{{ post.data.title }}</a></h3>
            {% if post.data.abstract or post.data.description %}<p>{{ post.data.abstract or post.data.description }}</p>{% endif %}
            {% if post.data.image or post.data.featured_image %}
              <img src="{{ post.data.image or post.data.featured_image }}" alt="" />
            {% endif %}
          </article>
        {% endif %}
      {% endfor %}
    </div>
  {% else %}
    <p>No publications yet.</p>
  {% endif %}
</section>

