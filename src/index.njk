---
layout: base.njk
title: Home
---

<section class="hero" id="home">
  <div class="hero-card hero-card--cover">
    <div class="hero-copy">
      <h1 class="hero-title">Patent Intelligence for High-Stakes Innovation.</h1>
      <h2>
      From semiconductor physics to strategic IP decisions — I help companies and IP firms secure, evaluate, and navigate complex technologies.
      </h2>
    </div>
    <nav class="hero-cta-strip" aria-label="Hero quick links">
      <a href="/services/">Strategic Services</a>
      <a href="/publications-projects/">Publications &amp; Projects</a>
      <a href="/contact/">Book a Consultation</a>
    </nav>
    <a class="hero-scroll" href="#services" data-slow-scroll aria-label="Scroll to Services">
      <img class="hero-scroll-img" src="/assets/img/scroll.png" alt="" aria-hidden="true" />
    </a>
  </div>
</section>

<section class="services" id="services">
  <div class="services-head">
    <p class="services-kicker">Services</p>
    <h2>Strategic support across the full patent lifecycle.</h2>
  </div>
  <div class="services-grid">
    <article class="service-card">
      <div class="service-text">
        <h3>Patentability &amp; Prior Art Analysis</h3>
        <p>
          Evidence-driven novelty and inventive-step assessments for complex technologies, with clear claim-risk framing.
        </p>
      </div>
      <figure class="service-media">
        <img src="/assets/img/filler.JPG" alt="Photonics and deep tech visual" />
      </figure>
    </article>
    <article class="service-card service-card--reverse">
      <div class="service-text">
        <h3>Freedom-to-Operate &amp; Risk Mapping</h3>
        <p>
          Focused FTO reviews and portfolio mapping to identify blocking rights, design-around paths, and exposure hotspots.
        </p>
      </div>
      <figure class="service-media">
        <img src="/assets/img/filler.JPG" alt="Analytics and risk mapping visual" />
      </figure>
    </article>
    <article class="service-card">
      <div class="service-text">
        <h3>Claim Drafting &amp; Prosecution Strategy</h3>
        <p>
          Technically precise claim architecture and prosecution planning aligned to business goals, licensing, and defensibility.
        </p>
      </div>
      <figure class="service-media">
        <img src="/assets/img/filler.JPG" alt="Claim strategy and innovation visual" />
      </figure>
    </article>
  </div>
</section>

<section class="articles-preview" id="publications">
  <div class="section-head">
    <h2>Latest Publications</h2>
    <a href="/publications-projects/">View all publications →</a>
  </div>

  {% if collections.posts and collections.posts.length %}
    <div class="cards">
      {% for post in collections.posts | reverse %}
        {% if loop.index0 < 3 %}
          <article class="card">
            {% set publicationUrl = post.data.publication_link or post.url %}
            <h3><a href="{{ publicationUrl }}" {% if post.data.publication_link %}target="_blank" rel="noopener noreferrer"{% endif %}>{{ post.data.title }}</a></h3>
            {% if post.data.abstract or post.data.description %}<p>{{ post.data.abstract or post.data.description }}</p>{% endif %}
            {% if post.data.image or post.data.featured_image %}
              <img src="{{ post.data.image or post.data.featured_image }}" alt="" />
            {% endif %}
          </article>
        {% endif %}
      {% endfor %}
    </div>
  {% else %}
    <p>No publications yet.</p>
  {% endif %}
</section>
