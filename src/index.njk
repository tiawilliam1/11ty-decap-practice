---
layout: base.njk
title: Home
---

<section class="hero">
  <div class="hero-card">
    <h1>Patent Engineering & IP Support</h1>
    <p>
      A clean practice site built with 11ty + Decap CMS. Publish articles from the admin panel and keep the main site fast and secure.
    </p>
  </div>
</section>

<div class="section-head">
  <h2>Latest Articles</h2>
  <a href="/articles/">View all →</a>
</div>

{% if collections.posts and collections.posts.length %}
  <div class="cards">
    {% for post in collections.posts | reverse %}
      {% if loop.index0 < 3 %}
        <article class="card">
          <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
          {% if post.data.description %}<p>{{ post.data.description }}</p>{% endif %}
          {% if post.data.featured_image %}
            <img src="{{ post.data.featured_image }}" alt="" />
          {% endif %}
        </article>
      {% endif %}
    {% endfor %}
  </div>
{% else %}
  <p>No articles yet.</p>
{% endif %}