---
layout: base.njk
title: Publications & Projects
permalink: /publications-projects/
---

<section class="page-intro">
  <h1>Publications &amp; Projects</h1>
  <p>
    Selected writing, technical insights, and project work focused on patent
    strategy in deep-tech domains.
  </p>
</section>

<section class="page-content">
  <h2>All Publications</h2>
  {% if collections.posts and collections.posts.length %}
    <div class="cards">
      {% for post in collections.posts | reverse %}
        {% set publicationUrl = post.data.publication_link or post.url %}
        <article class="card">
          <h3>{{ post.data.title }}</h3>
          {% if post.data.image or post.data.featured_image %}
            <img src="{{ post.data.image or post.data.featured_image }}" alt="" />
          {% endif %}
          {% if post.data.abstract or post.data.description %}
            <p>{{ post.data.abstract or post.data.description }}</p>
          {% endif %}
          <p>
            <a href="{{ publicationUrl }}" target="_blank" rel="noopener noreferrer">Go to publication</a>
          </p>
        </article>
      {% endfor %}
    </div>
  {% else %}
    <p>No publications yet.</p>
  {% endif %}
</section>
