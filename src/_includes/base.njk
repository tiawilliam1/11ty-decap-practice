<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title or "Site" }}</title>
    <link rel="stylesheet" href="/assets/css/styles.css" />
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>

  <body>
    <header class="site-header">
      <div class="wrap header-inner">
        <a class="brand" href="/" aria-label="Deep-Tech home">
          <img src="/assets/img/newlogo.png" alt="Deep Tech logo" />
        </a>

        <nav class="nav" aria-label="Primary">
          <a href="/#home" {% if page.url == "/" %}aria-current="page"{% endif %}>Home</a>
          <a href="/#services">Services</a>
          <a href="/#about">About Me</a>
          <a href="/#industries">Industries &amp; Clients</a>
          <a href="/#publications">Publications &amp; Projects</a>
        </nav>

        <a class="cta-pill" href="#contact">Contact</a>
      </div>
    </header>

    <main class="wrap">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="wrap footer-inner">
        <small>© {{ "now" | date("yyyy") }} Patent Engineer</small>
      </div>
    </footer>

    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", () => {
          const hash = window.location.hash || "";
          if (
            hash.includes("invite_token=") ||
            hash.includes("recovery_token=") ||
            hash.includes("confirmation_token=")
          ) {
            window.netlifyIdentity.open();
          }
        });
      }
    </script>
  </body>
</html>
