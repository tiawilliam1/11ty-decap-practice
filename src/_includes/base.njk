<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title or "Site" }}</title>
    <link rel="stylesheet" href="/assets/css/styles.css" />
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>

  <body{% if home_theme %} class="home-theme-{{ home_theme }}"{% endif %}>
    <header class="site-header">
      <div class="wrap header-inner">
        <a class="brand" href="/" aria-label="Deep-Tech home">
          <img src="{% if home_theme == 'alt' %}/assets/img/TechnoGenesispreview.png{% else %}/assets/img/otherlogo1.png{% endif %}" alt="Deep Tech logo" />
        </a>

        <nav class="nav" aria-label="Primary">
          <a href="/" {% if page.url == "/" %}aria-current="page"{% endif %}>Home</a>
          <a href="/services/" {% if page.url == "/services/" %}aria-current="page"{% endif %}>Services</a>
          <a href="/about/" {% if page.url == "/about/" %}aria-current="page"{% endif %}>About Me</a>
          <a href="/industries-clients/" {% if page.url == "/industries-clients/" %}aria-current="page"{% endif %}>Industries &amp; Clients</a>
          <a href="/publications-projects/" {% if page.url == "/publications-projects/" %}aria-current="page"{% endif %}>Publications &amp; Projects</a>
        </nav>

        <div class="header-actions">
          <details class="lang-switch">
            <summary aria-label="Language selector">
              <span class="lang-switch-icon" aria-hidden="true">🌐</span>
              <span class="lang-switch-label">EN</span>
              <span class="lang-switch-caret" aria-hidden="true">▾</span>
            </summary>
            <div class="lang-options">
              <a href="#" aria-disabled="true">English</a>
              <a href="#" aria-disabled="true">French</a>
            </div>
          </details>
          <a class="cta-pill" href="/contact/">Contact</a>
        </div>
      </div>
    </header>

    <main class="wrap">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="wrap footer-inner">
        <div class="footer-top">
          <div class="footer-brand">
            <a class="footer-logo-link" href="/" aria-label="Patent Engineer home">
              <img src="{% if home_theme == 'alt' %}/assets/img/TechnoGenesispreview.png{% else %}/assets/img/otherlogo1.png{% endif %}" alt="Patent Engineer logo" />
            </a>
            <div class="footer-brand-copy">
              <p class="footer-name">Meletis Mexis, PhD</p>
              <p class="footer-role">Patent Analyst and Engineer</p>
            </div>
          </div>

          <div class="footer-contact">
            <p class="footer-contact-label">Contact</p>
            <a href="mailto:contact@technogensis.fr">contact@technogensis.fr</a>
          </div>
        </div>

        <div class="footer-bottom">
          <small>© {{ "now" | date("yyyy") }} Patent Engineer</small>
          <small>Powered by Tia William</small>
        </div>
      </div>
    </footer>

    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", () => {
          const hash = window.location.hash || "";
          if (
            hash.includes("invite_token=") ||
            hash.includes("recovery_token=") ||
            hash.includes("confirmation_token=")
          ) {
            window.netlifyIdentity.open();
          }
        });
      }

      // Prevent stale #services hashes from forcing auto-scroll on refresh.
      if (window.location.pathname === "/" && window.location.hash === "#services") {
        history.replaceState(null, "", window.location.pathname + window.location.search);
        window.addEventListener(
          "load",
          () => window.scrollTo({ top: 0, left: 0, behavior: "auto" }),
          { once: true }
        );
      }

      document.documentElement.classList.add("reveal-ready");

      const revealItems = document.querySelectorAll("[data-reveal]");

      if (revealItems.length) {
        if ("IntersectionObserver" in window) {
          const revealObserver = new IntersectionObserver(
            (entries, observer) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;

                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              });
            },
            { threshold: 0.16, rootMargin: "0px 0px -8% 0px" }
          );

          revealItems.forEach((item) => revealObserver.observe(item));
        } else {
          revealItems.forEach((item) => item.classList.add("is-visible"));
        }
      }

      const slowLinks = document.querySelectorAll("[data-slow-scroll]");
      const easeInOut = (t) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);

      slowLinks.forEach((link) => {
        link.addEventListener("click", (event) => {
          const targetId = link.getAttribute("href");
          if (!targetId || !targetId.startsWith("#")) return;

          const target = document.querySelector(targetId);
          if (!target) return;

          event.preventDefault();

          const startY = window.scrollY;
          const targetY = target.getBoundingClientRect().top + window.scrollY - 16;
          const duration = 1200;
          const startTime = performance.now();

          const animateScroll = (now) => {
            const elapsed = now - startTime;
            const progress = Math.min(elapsed / duration, 1);
            const eased = easeInOut(progress);
            const nextY = startY + (targetY - startY) * eased;
            window.scrollTo(0, nextY);

            if (progress < 1) {
              requestAnimationFrame(animateScroll);
            }
          };

          requestAnimationFrame(animateScroll);
        });
      });

      const servicesGrid = document.querySelector(".services-grid");

      if (servicesGrid && "IntersectionObserver" in window) {
        servicesGrid.classList.add("observe-inview");

        const servicesObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              servicesGrid.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.2 }
        );

        servicesObserver.observe(servicesGrid);
      }

      const whyWork = document.querySelector(".why-work");

      if (whyWork && "IntersectionObserver" in window) {
        whyWork.classList.add("observe-inview");

        const whyWorkObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              whyWork.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.28 }
        );

        whyWorkObserver.observe(whyWork);
      }

      const articlesPreview = document.querySelector(".articles-preview");

      if (articlesPreview && "IntersectionObserver" in window) {
        articlesPreview.classList.add("observe-inview");

        const publicationsObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              articlesPreview.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.2 }
        );

        publicationsObserver.observe(articlesPreview);
      }

      const servicesListGrid = document.querySelector(".services-list-grid");

      if (servicesListGrid && "IntersectionObserver" in window) {
        servicesListGrid.classList.add("observe-inview");

        const serviceCards = servicesListGrid.querySelectorAll(".services-feature-card");
        serviceCards.forEach((card, index) => {
          card.style.setProperty("--services-delay", `${index * 180}ms`);
        });

        const servicesListObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              servicesListGrid.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.2 }
        );

        servicesListObserver.observe(servicesListGrid);
      }

      const highlightsAchievements = document.querySelector("#highlights-achievements");

      if (highlightsAchievements && "IntersectionObserver" in window) {
        highlightsAchievements.classList.add("observe-inview");

        const revealItems = highlightsAchievements.querySelectorAll(
          ".about-card li span"
        );

        revealItems.forEach((item, index) => {
          item.style.setProperty("--reveal-delay", `${index * 220}ms`);
        });

        const highlightsObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              highlightsAchievements.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.2 }
        );

        highlightsObserver.observe(highlightsAchievements);
      }

      const achievementsStrip = document.querySelector("#highlights-achievements .about-highlights-strip");

      if (achievementsStrip && "IntersectionObserver" in window) {
        achievementsStrip.classList.add("observe-inview");

        const stripItems = achievementsStrip.querySelectorAll(".about-highlight-item p");
        stripItems.forEach((item, index) => {
          item.style.setProperty("--reveal-delay", `${index * 220}ms`);
        });

        const stripObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              achievementsStrip.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.3 }
        );

        stripObserver.observe(achievementsStrip);
      }

    </script>
  </body>
</html>
