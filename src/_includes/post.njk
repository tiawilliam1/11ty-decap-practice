---
layout: base.njk
---

<article>
  <h1>{{ title }}</h1>
  {% if abstract or description %}<p><em>{{ abstract or description }}</em></p>{% endif %}
  {% if image or featured_image %}
    <img src="{{ image or featured_image }}" alt="" style="max-width:100%; border-radius:12px; margin: 12px 0;" />
  {% endif %}
  {% if publication_link %}
    <p><a href="{{ publication_link }}" target="_blank" rel="noopener noreferrer">Read publication</a></p>
  {% endif %}
  <div>
    {{ content | safe }}
  </div>
</article>
