title: Services
permalink: /services/
home_theme: alt
---

<section class="services-page">
  <div class="services-hero">
    <div class="services-hero-inner">
      <h1 data-reveal="up">Services</h1>
      <p class="services-short" data-reveal="up" style="--reveal-delay: 80ms;">
        Technical patent-information services tailored to deep-tech innovation and strategic IP decisions.
      </p>
    </div>

    <nav class="services-cta-strip" aria-label="Services quick links">
      <a href="#service-offerings" data-reveal="up" style="--reveal-delay: 200ms;">All Services</a>
      <a href="/about/" data-reveal="up" style="--reveal-delay: 280ms;">About Meletis</a>
      <a href="/contact/" data-reveal="up" style="--reveal-delay: 360ms;">Book a Consultation</a>
    </nav>
  </div>

  <section class="services-section-page" id="service-offerings">
    {% set service_items = [
      {
        "title": "Patentability Studies",
        "description": "Prior art searches across global patent databases and scientific literature to assess the novelty and inventive step of your invention before filing. Clear technical reports highlighting the closest prior art and its relevance to your claims."
      },
      {
        "title": "Freedom-to-Operate (FTO) Analysis",
        "description": "In-depth technical searches to identify third-party patents potentially relevant to your product or process. Structured comparative analysis between your technology and identified claims giving you the technical foundation for informed IP decisions."
      },
      {
        "title": "Invalidity & Prior Art Searches",
        "description": "Advanced prior art searches - patents, scientific publications, technical documentation, product literature - to challenge the validity of a targeted patent. Supports defence against infringement allegations and strengthens your position in licence negotiations."
      },
      {
        "title": "Patent Landscaping & Portfolio Mapping",
        "description": "Quantitative and qualitative analysis of patent portfolios. Competitive mapping, identification of key players, white spaces, and technology trends. Visual outputs tailored to your strategic questions."
      },
      {
        "title": "Competitive & Technology Watch",
        "description": "Continuous monitoring of competitor filings, technology alerts, and periodic reports aligned with your strategic priorities. Stay ahead of the patent landscape in your technology domain."
      },
      {
        "title": "Technical Consulting in Patent Information",
        "description": "Search strategy design, technical due diligence, technical sourcing for M&A or licensing contexts. Tailored advisory on how to leverage patent information for business decisions."
      },
      {
        "title": "Patent Search Training",
        "description": "Tailored sessions on patent databases, search methodologies, and professional tools for R&D teams, engineers, and IP professionals. From beginner search techniques to advanced analytical methods."
      }
    ] %}

    <div class="services-page-head" data-reveal="up">
      <h2>Service Offerings</h2>
      <p>Specialist support for engineering-heavy sectors where device-level understanding improves patent decisions.</p>
    </div>

    <div class="services-list-grid services-expandable-list">
      {% for item in service_items %}
        <details class="services-feature-card service-expandable">
          <summary>
            <span class="service-expandable-title">{{ item.title }}</span>
            <span class="service-expandable-icon" aria-hidden="true"></span>
          </summary>
          <div class="service-expandable-body">
            <p>{{ item.description }}</p>
          </div>
        </details>
      {% endfor %}
    </div>
  </section>
</section>
